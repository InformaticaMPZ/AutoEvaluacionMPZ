<odoo>
  <data>
    <!-- Vistas -->
    <record model="ir.ui.view" id="sevri_classification_tree">
      <field name="name">classification.tree</field>
      <field name="model">sev.classification</field>
      <field name="arch" type="xml">
        <tree>
          <field name="description" />
          <field name="event_type_id" />
          <field name="specifications" />
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="sevri_classification_form">
      <field name="name">classification.form</field>
      <field name="model">sev.classification</field>
      <field name="arch" type="xml">
        <form>
          <div class="container mt-4">
            <div class="card shadow-sm">
              <div class="card-header bg-primary">
                <h3 class="card-title mb-0 text-white">Información de la Clasificación</h3>
              </div>
              <div class="card-body">
                <div class="row">
                  <div class="col-12">
                    <div class="mb-3">
                      <label for="description" class="form-label fw-bold">Descripción</label>
                      <field name="description" style="margin-left: 1rem;" required="1"
                        placeholder="ej. Clasificación 2024" class="form-control" />
                    </div>
                    <div class="mb-3">
                      <label for="event_type_id" class="form-label fw-bold">Tipo de Evento</label>
                      <field name="event_type_id" style="margin-left: 1rem;"
                        class="form-control" />
                    </div>
                    <notebook>
                      <page name="specifications" string="Especificaciones">
                        <field name="specifications">
                          <tree>
                            <field name="description" />
                          </tree>
                        </field>
                      </page>
                    </notebook>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </form>
      </field>
    </record>

    <!-- Vista Kanban -->
    <record model="ir.ui.view" id="sevri_classification_kanban">
      <field name="name">classification.kanban</field>
      <field name="model">sev.classification</field>
      <field name="arch" type="xml">
        <kanban>
          <field name="description" />
          <field name="event_type_id" />
          <field name="specifications" />
          <templates>
            <t t-name="kanban-box">
              <div class="oe_kanban_card">
                <div class="oe_kanban_content">
                  <strong><field name="description"/></strong><br/>
                  <span><field name="event_type_id"/></span><br/>
                  <span><field name="specifications"/></span>
                </div>
              </div>
            </t>
          </templates>
        </kanban>
      </field>
    </record>

    <!-- Acciones -->
    <record model="ir.actions.act_window" id="sev_classification_action">
      <field name="name">Clasificaciones</field>
      <field name="res_model">sev.classification</field>
      <field name="view_mode">tree,form,kanban</field>
    </record>

    <!-- Menú -->
    <menuitem
      id="sev_classifications"
      name="Clasificaciones"
      action="sev_classification_action"
      parent="sevri_root"
    />
  </data>
</odoo>
